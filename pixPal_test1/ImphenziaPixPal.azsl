#pragma once

ShaderResourceGroupSemantic PixPalPerMaterialSemantic
{
    FrequencyId = 2;
    ShaderVariantFallback = 128;
}

#include <Atom/Features/SrgSemantics.azsli>

#include <scenesrg_all.srgi>
#include <viewsrg_all.srgi>
#include <Atom/Features/PBR/DefaultObjectSrg.azsli>
#include <Atom/Features/InstancedTransforms.azsli>
#include <Atom/Features/Pipeline/Forward/ForwardPassOutput.azsli>

ShaderResourceGroup PixPalSrg : PixPalPerMaterialSemantic
{
    Texture2D m_paletteTexture;
    Texture2D m_attributesTexture;
    Texture2D m_emissionTexture;
    
    Sampler m_pointSampler;

    float m_animationSpeed;
    float m_neonStrength;
}

struct VertexShaderInput
{
    float3 m_position : POSITION;
    float3 m_normal   : NORMAL;
    float2 m_uv       : UV0;
};

struct VertexShaderOutput
{
    float4 m_position : SV_Position;
    float2 m_uv       : TEXCOORD0;
    float3 m_worldPos : TEXCOORD1;
    float3 m_normal   : TEXCOORD2;
};

VertexShaderOutput MainVS(VertexShaderInput IN, uint instanceId : SV_InstanceID)
{
    VertexShaderOutput OUT;
    
    float4x4 objectToWorld = GetObjectToWorldMatrix(instanceId);
    float4 worldPosition4 = mul(objectToWorld, float4(IN.m_position, 1.0));
    
    OUT.m_position = mul(ViewSrg::m_viewProjectionMatrix, worldPosition4);
    OUT.m_worldPos = worldPosition4.xyz;
    OUT.m_uv = IN.m_uv;
    
    float3x3 objectToWorldIT = GetObjectToWorldMatrixInverseTranspose(instanceId);
    OUT.m_normal = normalize(mul(objectToWorldIT, IN.m_normal));
    
    return OUT;
}

ForwardPassOutput MainPS(VertexShaderOutput IN)
{
    ForwardPassOutput OUT;
    
    // Sample with nearest-neighbor (pixel-art perfect)
    float4 paletteColor  = PixPalSrg::m_paletteTexture.Sample(PixPalSrg::m_pointSampler, IN.m_uv);
    float4 attributes    = PixPalSrg::m_attributesTexture.Sample(PixPalSrg::m_pointSampler, IN.m_uv);
    float4 emissionColor = PixPalSrg::m_emissionTexture.Sample(PixPalSrg::m_pointSampler, IN.m_uv);
    
    float animationFactor = attributes.r;
    float metallicFactor  = attributes.g;   // unused in this simple forward pass (extendable)
    float roughnessFactor = attributes.b;   // unused in this simple forward pass (extendable)
    
    // === Animated Neon (exact Blender node group behavior) ===
    float time = SceneSrg::m_time * PixPalSrg::m_animationSpeed;
    
    float3 animatedOffset = IN.m_worldPos * float3(0.03, 0.035, 0.0);
    float pulse = sin(time + animatedOffset.x + animatedOffset.y) * 0.5 + 0.5;
    
    float3 emissive = emissionColor.rgb * PixPalSrg::m_neonStrength * animationFactor * pulse;
    
    float3 finalColor = paletteColor.rgb + emissive;
    
    OUT.m_diffuseColor = float4(finalColor, paletteColor.a);
    OUT.m_specularColor = float4(0.0, 0.0, 0.0, 0.0);
    
    return OUT;
}
