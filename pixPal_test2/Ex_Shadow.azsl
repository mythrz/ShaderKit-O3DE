#pragma once

#include <scenesrg_all.srgi>
#include <viewsrg_all.srgi>
#include <Atom/Features/PBR/DefaultObjectSrg.azsli>
#include <Atom/Features/InstancedTransforms.azsli>

ShaderResourceGroup PixPalShadowDrawSrg : SRG_PerDraw
{
}

struct VSIn { float3 m_position : POSITION; };

struct VSOut { precise float4 m_position : SV_Position; };

VSOut MainVS(VSIn IN, uint instanceId : SV_InstanceID)
{
    VSOut OUT;
    float4 worldPos = mul(GetObjectToWorldMatrix(instanceId), float4(IN.m_position, 1.0));
    OUT.m_position = mul(ViewSrg::m_viewProjectionMatrix, worldPos);
    return OUT;
}
